<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | Nexus</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" type="text/css" href="https://cdn.jsdelivr.net/npm/toastify-js/src/toastify.min.css">
    <script type="text/javascript" src="https://cdn.jsdelivr.net/npm/toastify-js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --primary: #4e73df;
            --secondary: #858796;
            --success: #1cc88a;
            --info: #36b9cc;
            --warning: #f6c23e;
            --danger: #e74a3b;
            --dark: #5a5c69;
            --light: #f8f9fc;
        }

        body {
            background-color: #f8f9fc;
            font-family: 'Inter', sans-serif;
        }

        #wrapper {
            display: flex;
        }

        #sidebar {
            width: 250px;
            background: linear-gradient(180deg, #4e73df 10%, #224abe 100%);
            min-height: 100vh;
            color: white;
            transition: all 0.3s;
        }

        .sidebar-brand {
            padding: 1.5rem 1rem;
            font-size: 1.2rem;
            font-weight: 800;
            text-align: center;
        }

        .nav-item .nav-link {
            color: rgba(255, 255, 255, 0.8);
            padding: 0.75rem 1rem;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .nav-item .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.1);
        }

        .nav-item .nav-link.active {
            color: white;
            font-weight: 700;
        }

        #content-wrapper {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
        }

        #navbar {
            background: white;
            padding: 1rem 2rem;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
            display: flex;
            justify-content: flex-end;
            align-items: center;
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
        }

        .main-content {
            padding: 2rem;
        }

        .card {
            border: none;
            box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.1);
            border-radius: 12px;
            margin-bottom: 1.5rem;
        }

        .card-header {
            background: white;
            border-bottom: 1px solid #e3e6f0;
            font-weight: 700;
            color: #4e73df;
        }

        .btn-logout {
            color: #e74a3b;
            font-weight: 600;
            text-decoration: none;
        }

        .btn-logout:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <div id="sidebar">
            <div class="sidebar-brand">
                <i class="fas fa-layer-group"></i> NEXUS
            </div>
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link active" href="#"><i class="fas fa-fw fa-tachometer-alt"></i> Dashboard</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-fw fa-chart-area"></i> Analytics</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-fw fa-user"></i> Profile</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" href="#"><i class="fas fa-fw fa-cog"></i> Settings</a>
                </li>
            </ul>
        </div>

        <!-- Content Wrapper -->
        <div id="content-wrapper">
            <!-- Navbar -->
            <nav id="navbar">
                <div class="user-profile">
                    <span class="text-gray-600 small me-2"><%= user.name %></span>
                    <img class="user-avatar" src="<%= user.avatar %>" alt="Avatar">
                    <div class="ms-3 border-start ps-3">
                        <a href="/auth/logout" class="btn-logout"><i class="fas fa-sign-out-alt"></i> Logout</a>
                    </div>
                </div>
            </nav>

            <!-- Main Content -->
            <div class="main-content">
                <div class="d-sm-flex align-items-center justify-content-between mb-4">
                    <h1 class="h3 mb-0 text-gray-800">Dashboard Overview</h1>
                    <div class="d-flex gap-2">
                        <span class="badge bg-success d-flex align-items-center px-3"><i class="fas fa-circle fa-xs me-2"></i> System Online</span>
                        <a href="#" class="btn btn-sm btn-primary shadow-sm"><i class="fas fa-download fa-sm text-white-50"></i> Generate Report</a>
                    </div>
                </div>

                <div class="row">
                    <!-- User Profile Card -->
                    <div class="col-xl-4 col-md-6 mb-4">
                        <div class="card border-left-primary h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">User Profile</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800"><%= user.name %></div>
                                        <div class="text-muted small"><%= user.email %></div>
                                        <div class="mt-2">
                                            <span class="badge bg-primary">Role: User</span>
                                        </div>
                                    </div>
                                    <div class="col-auto">
                                        <img src="<%= user.avatar %>" alt="Avatar" class="rounded-circle" style="width: 60px;">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- System Status Card -->
                    <div class="col-xl-4 col-md-6 mb-4">
                        <div class="card border-left-success h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">System Status</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">Healthy</div>
                                        <div class="progress progress-sm mt-2">
                                            <div class="progress-bar bg-success" role="progressbar" style="width: 98%" aria-valuenow="98" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                        <div class="text-muted small mt-1">Uptime: 99.9%</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-server fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- API Status Card -->
                    <div class="col-xl-4 col-md-6 mb-4">
                        <div class="card border-left-info h-100 py-2">
                            <div class="card-body">
                                <div class="row no-gutters align-items-center">
                                    <div class="col mr-2">
                                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">API Integrations</div>
                                        <div class="h5 mb-0 font-weight-bold text-gray-800">3 Active</div>
                                        <div class="text-muted small">Requests today: 1,240</div>
                                    </div>
                                    <div class="col-auto">
                                        <i class="fas fa-plug fa-2x text-gray-300"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- API Data Section (Phase 4) -->
                <div class="row">
                    <div class="col-lg-8">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
                                <h6 class="m-0 font-weight-bold text-primary">Live API Data Feed</h6>
                                <div class="dropdown no-arrow">
                                    <a class="dropdown-toggle" href="#" role="button" id="dropdownMenuLink" data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                        <i class="fas fa-ellipsis-v fa-sm fa-fw text-gray-400"></i>
                                    </a>
                                </div>
                            </div>
                            <div class="card-body" id="api-data-container">
                                <div class="text-center py-5">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="text-muted mt-2">Fetching real-time data...</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-4">
                        <!-- Quick Actions -->
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
                            </div>
                            <div class="card-body">
                                <button id="refresh-btn" class="btn btn-outline-primary w-100 mb-2 text-start"><i class="fas fa-sync me-2"></i> Refresh Data</button>
                                <button class="btn btn-outline-secondary w-100 mb-2 text-start"><i class="fas fa-user-edit me-2"></i> Edit Profile</button>
                                <button class="btn btn-outline-danger w-100 text-start"><i class="fas fa-exclamation-triangle me-2"></i> Report Issue</button>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Analytics Section (Phase 5) -->
                <div class="row">
                    <div class="col-lg-12">
                        <div class="card shadow mb-4">
                            <div class="card-header py-3">
                                <h6 class="m-0 font-weight-bold text-primary">API Usage Analytics</h6>
                            </div>
                            <div class="card-body">
                                <div class="chart-area" style="height: 300px;">
                                    <canvas id="usageChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', async () => {
            // Initialize Chart
            const ctx = document.getElementById('usageChart').getContext('2d');
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'],
                    datasets: [{
                        label: 'API Requests',
                        data: [1200, 1900, 1500, 2100, 1800, 2400, 2200],
                        backgroundColor: 'rgba(78, 115, 223, 0.05)',
                        borderColor: 'rgba(78, 115, 223, 1)',
                        pointRadius: 3,
                        pointBackgroundColor: 'rgba(78, 115, 223, 1)',
                        pointBorderColor: 'rgba(78, 115, 223, 1)',
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true },
                        x: { grid: { display: false } }
                    },
                    plugins: { legend: { display: false } }
                }
            });

            // Fetch API Data
            const container = document.getElementById('api-data-container');
            const refreshBtn = document.getElementById('refresh-btn');

            async function fetchData() {
                if (refreshBtn) refreshBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i> Refreshing...';
                
                try {
                    const response = await fetch('/api/data');
                    const result = await response.json();

                    if (result.success) {
                        const data = result.data;
                        container.innerHTML = `
                            <div class="table-responsive">
                                <table class="table table-hover">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Asset</th>
                                            <th>Price (USD)</th>
                                            <th>24h Change</th>
                                            <th>Status</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <tr>
                                            <td><i class="fab fa-bitcoin text-warning me-2"></i> Bitcoin</td>
                                            <td>$${data.bitcoin.price.toLocaleString()}</td>
                                            <td class="${data.bitcoin.change24h >= 0 ? 'text-success' : 'text-danger'}">
                                                ${data.bitcoin.change24h.toFixed(2)}%
                                            </td>
                                            <td><span class="badge bg-success">Live</span></td>
                                        </tr>
                                        <tr>
                                            <td><i class="fab fa-ethereum text-primary me-2"></i> Ethereum</td>
                                            <td>$${data.ethereum.price.toLocaleString()}</td>
                                            <td class="${data.ethereum.change24h >= 0 ? 'text-success' : 'text-danger'}">
                                                ${data.ethereum.change24h.toFixed(2)}%
                                            </td>
                                            <td><span class="badge bg-success">Live</span></td>
                                        </tr>
                                    </tbody>
                                </table>
                            </div>
                            <div class="mt-3 small text-muted text-end">
                                Last updated: ${new Date(data.timestamp).toLocaleString()}
                            </div>
                        `;
                        
                        Toastify({
                            text: "Data updated successfully",
                            duration: 3000,
                            gravity: "top",
                            position: "right",
                            style: { background: "linear-gradient(to right, #00b09b, #96c93d)" }
                        }).showToast();
                    } else {
                        container.innerHTML = `<div class="alert alert-danger">${result.message}</div>`;
                    }
                } catch (error) {
                    container.innerHTML = `<div class="alert alert-danger">Failed to fetch API data.</div>`;
                    console.error('Fetch error:', error);
                } finally {
                    if (refreshBtn) refreshBtn.innerHTML = '<i class="fas fa-sync me-2"></i> Refresh Data';
                }
            }

            if (refreshBtn) {
                refreshBtn.addEventListener('click', fetchData);
            }

            // Initial fetch
            fetchData();
        });
    </script>
</body>
</html>
